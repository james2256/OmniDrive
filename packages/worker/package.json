{
  "name": "@omnidrive/worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8888",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "build:node": "esbuild src/node-server.ts --bundle --platform=node --outfile=dist/node-server.cjs --external:better-sqlite3",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "db:migrate:local": "wrangler d1 migrations apply omnidrive --local",
    "db:migrate:remote": "wrangler d1 migrations apply omnidrive --remote",
    "db:reset:local": "node scripts/reset.mjs --local",
    "db:reset:remote": "node scripts/reset.mjs --remote"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/zod-validator": "^0.9.0",
    "better-sqlite3": "^13.0.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.31",
    "node-cron": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260721.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
