{
  "name": "omnidrive",
  "version": "0.9.7",
  "description": "Unified multi-Google Drive storage gateway built on Cloudflare Workers",
  "private": true,
  "license": "MIT",
  "author": "abilfida",
  "repository": {
    "type": "git",
    "url": "https://github.com/abilfida/omnidrive.git"
  },
  "workspaces": [
    "packages/worker",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,green \"npm:dev:worker\" \"npm:dev:web\"",
    "dev:worker": "npm run dev --prefix packages/worker",
    "dev:web": "npm run dev --prefix packages/web -- --host 0.0.0.0",
    "test": "npm run test --prefix packages/worker",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p packages/worker/tsconfig.json --noEmit && tsc -p packages/web/tsconfig.json --noEmit",
    "migrate:remote": "npm run db:migrate:remote --prefix packages/worker",
    "deploy:code": "npm run build --prefix packages/worker && npm run deploy --prefix packages/worker && npm run build --prefix packages/web && npm run deploy --prefix packages/web",
    "deploy:full": "npm run db:migrate:remote --prefix packages/worker && npm run deploy:code",
    "build:web": "npm run build --prefix packages/web",
    "build:worker": "npm run build --prefix packages/worker"
  },
  "devDependencies": {
    "@clack/prompts": "^1.5.1",
    "@eslint/js": "^9.39.5",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
