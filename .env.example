# ==========================================
# OMNIDRIVE ENVIRONMENT VARIABLES
# ==========================================
# Gunakan file ini sebagai referensi. Copy menjadi `.env` di root folder.
# Semua variabel akan dibagikan (symlink) ke folder web dan worker.
# Jika `.env` di root tidak ada, aplikasi akan mencoba membaca
# dari `.env` (di web) atau `.dev.vars` (di worker).

# ------------------------------------------
# GENERAL / PORT CONFIGURATION
# ------------------------------------------
# Port utama untuk web dan worker (opsional, jika tidak menggunakan default)
#PORT=8999
WEB_PORT=8999
WORKER_PORT=8888

# URL dasar untuk Frontend dan Worker
FRONTEND_URL=http://localhost:8999
WORKER_URL=http://localhost:8888

# ------------------------------------------
# WEB CONFIGURATION
# ------------------------------------------
# API URL yang digunakan oleh Vite di frontend.
# Di mode development lokal, Vite secara otomatis akan proxy ke API,
# namun VITE_API_URL tetap berguna untuk memastikan path atau saat build.
VITE_API_URL=http://localhost:8888

# ------------------------------------------
# WORKER / AUTH SECRETS
# ------------------------------------------
# Kredensial Google OAuth 2.0 (Dapatkan dari Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Secret untuk otentikasi sesi pengguna
# Generate dengan: node -e "console.log(crypto.randomUUID().replace(/-/g,''))"
JWT_SECRET=your-random-32-char-jwt-secret-here

# Kunci enkripsi untuk mengenkripsi token (contoh: akses token pihak ketiga)
# Generate dengan: node -e "console.log(crypto.randomUUID().replace(/-/g,''))"
TOKEN_ENCRYPTION_KEY=your-random-32-char-encryption-key
