# ==========================================
# OMNIDRIVE ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to `.env` in the root folder and fill in real values.
# All vars are shared (symlinked) to the web and worker packages.
# If root `.env` is missing, the app reads from `.env` (web) or `.dev.vars` (worker).

# ------------------------------------------
# GENERAL / PORT CONFIGURATION
# ------------------------------------------
# Main ports for web and worker (dev only; production uses Cloudflare URLs)
#PORT=8999
WEB_PORT=8999
WORKER_PORT=8888

# Base URLs for Frontend and Worker
# In dev: http://localhost:8999 / http://localhost:8888
# In prod: https://your-app.pages.dev / https://your-worker.workers.dev
FRONTEND_URL=http://localhost:8999
WORKER_URL=http://localhost:8888

# ------------------------------------------
# WEB CONFIGURATION
# ------------------------------------------
# API base URL for the frontend. LEAVE EMPTY (recommended) so requests use
# same-origin /api — Vite proxy (dev) and Pages Functions (production).
# The session cookie then persists on the frontend host after tab close.
# Set only if you intentionally call the Worker directly (cross-site, cookie may drop).
VITE_API_URL=

# ------------------------------------------
# WORKER / AUTH SECRETS
# ------------------------------------------
# Google OAuth 2.0 credentials (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secret for signing session JWTs (shared-link sessions).
# Generate: node -e "console.log(crypto.randomUUID().replace(/-/g,''))"
# Or:       openssl rand -hex 16
# Min 32 chars.
JWT_SECRET=your-random-32-char-jwt-secret-here

# Encryption key for OAuth tokens and S3 secret keys at rest (AES-256-GCM).
# Generate: node -e "console.log(crypto.randomUUID().replace(/-/g,''))"
# Or:       openssl rand -hex 16
# Min 32 chars. KEEP SAFE — losing this means all connected Drives must be re-authorized.
TOKEN_ENCRYPTION_KEY=your-random-32-char-encryption-key

# ------------------------------------------
# OPTIONAL: SECURITY
# ------------------------------------------
# If set, the first super-admin registration requires this token (extra security).
# If empty, first registration is open (default).
# BOOTSTRAP_TOKEN=

# ------------------------------------------
# DOCKER / SELF-HOSTED ONLY
# ------------------------------------------
# These are only used by the Node.js runtime (node-server.ts), NOT Cloudflare Workers.
# Directory for SQLite files (default: ./data)
# DATA_DIR=./data
# Directory for built frontend (default: ../web/dist)
# STATIC_DIR=../web/dist
# HTTP port for the unified Node server (default: 8080)
# PORT=8080
